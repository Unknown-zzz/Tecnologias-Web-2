# ============================================================
# APUNTE TECNICO - SISTEMA ECOMMERCE (TW2)
# ============================================================
# Este archivo documenta la configuracion principal del sistema.
# Nota: actualmente la app lee valores desde config/config.php.
# Este .env queda como referencia central para despliegue/soporte.

# ------------------------------------------------------------
# APP
# ------------------------------------------------------------
APP_NAME="Tienda Amiga"
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE="America/La_Paz"
APP_URL="http://localhost:8080"
APP_ENTRYPOINT="index.php"

# ------------------------------------------------------------
# BASE DE DATOS (MySQL / MariaDB)
# ------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=ecommerce
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_general_ci
DB_TIMEZONE="-04:00"

# ------------------------------------------------------------
# SCRIPTS SQL QUE USA EL SISTEMA
# ------------------------------------------------------------
# 1) Estructura inicial y datos base
SQL_SCHEMA_FILE="sql/ecommerce (1).sql"
# 2) Procedimientos almacenados (obligatorio para modulos principales)
SQL_STORED_PROCEDURES_FILE="sql/stored_procedures.sql"
# 3) Migracion de pagos QR
SQL_QR_MIGRATION_FILE="sql/qr_payment_migration.sql"

# ------------------------------------------------------------
# OBJETOS CLAVE EN BD
# ------------------------------------------------------------
# Tablas principales esperadas:
# - Cuenta, Cliente, Producto, Categoria, Marca, Industria, Sucursal
# - DetalleProductoSucursal, NotaVenta, DetalleNotaVenta, QrPayment
#
# Stored procedures importantes:
# - sp_cuenta_find, sp_cuenta_create
# - sp_producto_all_active, sp_producto_all_admin, sp_producto_find
# - sp_categoria_all, sp_marca_all, sp_industria_all
# - sp_venta_create, sp_venta_all, sp_venta_find, sp_venta_details

# ------------------------------------------------------------
# MODULOS DEL SISTEMA
# ------------------------------------------------------------
# - Autenticacion: login/registro de usuarios
# - Tienda: catalogo, detalle, carrito
# - Checkout: compra, resumen, pago QR
# - Admin: dashboard, productos, categorias, marcas, industrias, ventas
# - Reportes: comprobantes en storage/receipts

# ------------------------------------------------------------
# RUTAS PRINCIPALES (REFERENCIA)
# ------------------------------------------------------------
ROUTE_HOME="index.php?r=home"
ROUTE_LOGIN="index.php?r=login"
ROUTE_REGISTER="index.php?r=register"
ROUTE_CART="index.php?r=cart"
ROUTE_CHECKOUT="index.php?r=checkout"
ROUTE_ADMIN_LOGIN="index.php?r=admin/login"
ROUTE_ADMIN_DASHBOARD="index.php?r=admin/dashboard"
ROUTE_ADMIN_PRODUCTS="index.php?r=admin/products"
ROUTE_ADMIN_SALES="index.php?r=admin/sales"

# ------------------------------------------------------------
# STORAGE / ARCHIVOS
# ------------------------------------------------------------
STORAGE_RECEIPTS_PATH="storage/receipts"
RESOURCES_PATH="resources"
PRODUCT_IMAGES_PATH="resources/imagenes"
LOGO_PATH="resources/logo"

# ------------------------------------------------------------
# SERVIDOR LOCAL DE DESARROLLO
# ------------------------------------------------------------
DEV_SERVER_HOST=localhost
DEV_SERVER_PORT=8080
DEV_SERVER_COMMAND="php -S localhost:8080"

# ------------------------------------------------------------
# USUARIO ADMIN (SOLO REFERENCIA DE ENTORNO LOCAL)
# ------------------------------------------------------------
# Ajustar segun datos reales de tu BD.
ADMIN_LOGIN_ROUTE="index.php?r=admin/login"
ADMIN_DEFAULT_USER="administrador"
ADMIN_DEFAULT_PASS="12345"

# ============================================================
# FIN DEL APUNTE
# ============================================================
